
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ==================== SALES GROUPS ==================== -->
        <record id="group_sales_executive" model="res.groups">
            <field name="name">Sales Executive</field>
        </record>

        <record id="group_sales_manager" model="res.groups">
            <field name="name">Sales Manager</field>
            <field name="implied_ids" eval="[(4, ref('group_sales_executive'))]"/>
        </record>

        <!-- ==================== PURCHASE GROUPS ==================== -->
        <record id="group_purchase_officer" model="res.groups">
            <field name="name">Purchase Officer</field>
        </record>

        <record id="group_purchase_manager" model="res.groups">
            <field name="name">Purchase Manager</field>
            <field name="implied_ids" eval="[(4, ref('group_purchase_officer'))]"/>
        </record>

        <!-- ==================== ESTATE SALES GROUP ==================== -->
        <record id="group_estate_sales_executive" model="res.groups">
            <field name="name">Estate Sales Executive</field>
        </record>

    </data>
</odoo>


