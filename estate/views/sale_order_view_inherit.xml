<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_view_form_inherit_security" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.security</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Restrict Confirm Button -->
            <xpath expr="//button[@name='action_confirm']" position="attributes">
                <attribute name="groups">estate.group_estate_sales_executive</attribute>
            </xpath>

        </field>
    </record>
</odoo>
