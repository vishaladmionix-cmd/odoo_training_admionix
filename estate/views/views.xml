<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══ LIST VIEW ═══ -->
    <record id="estate_property_view_list" model="ir.ui.view">
        <field name="name">estate.property.list</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <list string="Properties">
                <field name="name"/>
                <field name="property_type_id"/>
                <field name="postcode"/>
                <field name="bedrooms"/>
                <field name="expected_price"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- ═══ FORM VIEW ═══ -->
    <record id="estate_property_view_form" model="ir.ui.view">
        <field name="name">estate.property.form</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <form string="Property">
                <header>
                    <button name="action_sold"
                            type="object"
                            string="Mark as Sold"
                            class="btn-primary"/>
                    <button name="action_cancel"
                            type="object"
                            string="Cancel"
                            class="btn-secondary"/>
                    <button name="action_view_accepted_offers"
                            type="object"
                            string="Accepted Offers"
                            class="btn-primary"/>
                    <button name="action_get_new_properties"
                            type="object"
                            string="New Properties"
                            class="btn-secondary"/>
                    <button name="action_count_new_properties"
                            type="object"
                            string="Count New"
                            class="btn-secondary"/>
                    <button name="action_browse_example"
                            type="object"
                            string="Browse Example"
                            class="btn-secondary"/>
                </header>
                <sheet>
                    <div name="button_box" class="oe_button_box">
                        <button type="object"
                                name="action_view_offers"
                                class="oe_stat_button"
                                icon="fa-handshake-o">
                            <field name="offer_count"
                                   string="Offers"
                                   widget="statinfo"/>
                        </button>
                    </div>

                    <group>
                        <group string="Property Details">
                            <field name="name"/>
                            <field name="property_type_id"/>
                            <field name="postcode"/>
                            <field name="date_availability"/>
                            <field name="validity"/>
                            <field name="date_deadline"/>
                            <field name="state" widget="selection"/>
                            <field name="tag_ids" widget="many2many_tags"/>
                        </group>
                        <group string="Pricing">
                            <field name="expected_price"/>
                            <field name="selling_price"/>
                            <field name="bedrooms"/>
                            <field name="garage"/>
                            <field name="living_area"/>
                            <field name="facades"/>
                            <field name="garden"/>
                            <field name="garden_area" invisible="not garden"/>
                            <field name="garden_orientation" invisible="not garden"/>
                            <field name="total_area"/>
                        </group>
                    </group>

                    <group string="Property Extra Details">
                        <field name="property_category"/>
                        <field name="floor_number"/>
                        <field name="has_pool"/>
                        <field name="maintenance_fee"/>
                        <field name="is_furnished"/>
                    </group>

                    <group string="Description">
                        <field name="description"/>
                    </group>

                    <group string="Offers">
                        <field name="offer_ids">
                            <list>
                                <field name="price"/>
                                <field name="partner_id"/>
                                <field name="partner_phone"/>
                                <field name="status"/>
                            </list>
                        </field>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ═══ OFFER LIST VIEW ═══ -->
    <record id="estate_property_offer_view_list" model="ir.ui.view">
        <field name="name">estate.property.offer.list</field>
        <field name="model">estate.property.offer</field>
        <field name="arch" type="xml">
            <list string="Offers">
                <field name="property_id"/>
                <field name="partner_id"/>
                <field name="partner_phone"/>
                <field name="price"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <!-- ═══ OFFER FORM VIEW ═══ -->
    <record id="estate_property_offer_view_form" model="ir.ui.view">
        <field name="name">estate.property.offer.form</field>
        <field name="model">estate.property.offer</field>
        <field name="arch" type="xml">
            <form string="Offer">
                <sheet>
                    <group string="Offer Details">
                        <field name="property_id"/>
                        <field name="partner_id"/>
                        <field name="partner_phone"/>
                        <field name="price"/>
                        <field name="status"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ═══ SERVER ACTION ═══ -->
    <record id="action_reset_property_to_new" model="ir.actions.server">
        <field name="name">Reset to New</field>
        <field name="model_id" ref="estate.model_estate_property"/>
        <field name="binding_model_id" ref="estate.model_estate_property"/>
        <field name="binding_type">action</field>
        <field name="state">code</field>
        <field name="code">records.action_reset_to_new()</field>
    </record>

    <!-- ═══ ACTION ═══ -->
    <record id="estate_property_action" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="res_model">estate.property</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ═══ MENUS ═══ -->
    <menuitem
            id="estate_menu_root"
            name="Real Estate"
            sequence="10"/>

    <menuitem
            id="estate_menu_properties"
            name="Properties"
            parent="estate_menu_root"
            sequence="10"/>

    <menuitem
            id="estate_menu_all_properties"
            name="All Properties"
            parent="estate_menu_properties"
            action="estate_property_action"
            sequence="10"/>

</odoo>
