<odoo>
    <record id="view_hospital_emergency_form" model="ir.ui.view">
    <field name="name">hospital.emergency.wizard.form</field>
    <field name="model">hospital.emergency.wizard</field>
    <field name="arch" type="xml">
        <form string="Emergency">
            <sheet>
                <group>
                    <field name="hospital_id" readonly="1"/>
                    <field name="date" required="1"/>
                </group>

                <separator string="Reason"/>
                <field name="reason" required="1" nolabel="1" placeholder="Enter reason"/>
            </sheet>
        </form>
    </field>
</record>
    <record id="view_hospital_mangement_form" model="ir.ui.view">
        <field name="name">hospital.management.form</field>
        <field name="model">hospital.management</field>
        <field name="arch" type ='xml'>
            <form>
                <header>
                <button name="action_open_emergency_wizard"
                        type="object"
                        string="Emergency"
                        class="oe_highlight"/>
            </header>
                <sheet>
                    <group>
                        <field name = 'first_name'/>
                        <field name = 'last_name'/>
                        <field name = 'email'/>
                        <field name = 'file'/>
                        <field name = 'image'/>
                        <field name = 'address'/>
                        <field name = 'gender'/>
                        <field name = 'age'/>
                        <field name='is_admit'/>

                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_hospital_mangement_list" model="ir.ui.view">
        <field name ='name'>hospital.management.list</field>
        <field name ='model'>hospital.management</field>
        <field name ='arch' type="xml">
            <list>
                <field name = 'first_name'/>
                <field name = 'last_name'/>
                <field name = 'email'/>
                <field name = 'address'/>
                <field name = 'gender'/>
                <field name = 'age'/>
                <field name='is_admit'/>

            </list>
        </field>
    </record>
     <record id="view_hospital_management_search" model="ir.ui.view">
           <field name="name">hospital.management.search</field>
           <field name="model">hospital.management</field>
           <field name="arch" type="xml">
               <search>
                   <field name="first_name"/>
                    <field name="last_name"/>

                    <filter string="Admit"
                        name="admit"
                        domain="[('is_admit', '=', True)]"/>

                        <filter string="Gender"
                            name="gender"
                            context="{'group_by': 'gender'}"/>
                    <filter string = 'Age'
                            name = 'age'
                            domain="[('age', '>', 18)]" />

               </search>
           </field>
    </record>

    <record id="action_hospital_management" model="ir.actions.act_window">
        <field name="name">Hospitals</field>
        <field name="res_model">hospital.management</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref = 'view_hospital_management_search'/>
        <field name="context">
            {
            'search_default_admit' : 1,
            'search_default_gender' : 1
            }
        </field>
    </record>


    <menuitem id="menu_hospital_management_root" name="Hospital"/>

    <menuitem
        id="menu_hospital_management"
        name="Hospitals"
        parent="menu_hospital_management_root"
        action="action_hospital_management"/>

</odoo>