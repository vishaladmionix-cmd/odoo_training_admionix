<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="jewellery_sale_wizard_view" model="ir.ui.view">
        <field name="name">jewellery.sale.wizard.form</field>
        <field name="model">jewellery.sale.wizard</field>
        <field name="arch" type="xml">

            <form string="Create Sale">

                <group>
                    <field name="sale_order_id" invisible="1"/>
                    <field name="product_line_id"/>
                </group>

                <footer>
                    <button name="action_apply"
                            string="Add to Sale Order"
                            type="object"
                            class="btn-primary"/>

                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>

            </form>

        </field>
    </record>

</odoo>