<odoo>
    <data>

        <!-- Odoo 19: Use res.groups.privilege instead of ir.module.category -->
        <record id="privilege_library" model="res.groups.privilege">
            <field name="name">Library</field>
            <field name="sequence">10</field>
        </record>

        <record id="group_library_librarian" model="res.groups">
            <field name="name">Librarian</field>
            <field name="privilege_id" ref="privilege_library"/>
        </record>

        <record id="group_library_member" model="res.groups">
            <field name="name">Member</field>
            <field name="privilege_id" ref="privilege_library"/>
        </record>

    </data>
</odoo>