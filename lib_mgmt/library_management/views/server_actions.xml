<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Send Book Issued Email -->
    <record id="action_send_mail_book_issue" model="ir.actions.server">
        <field name="name">Send Book Issued Email</field>
        <field name="model_id" ref="model_library_borrow"/>
        <field name="binding_model_id" ref="model_library_borrow"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">
if records:
    records.action_send_mail()
        </field>
    </record>

    <!-- Mark Overdue Books as Late -->
    <record id="action_mark_late_books" model="ir.actions.server">
        <field name="name">Mark as Late</field>
        <field name="model_id" ref="model_library_borrow"/>
        <field name="binding_model_id" ref="model_library_borrow"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">
if records:
    today = fields.Datetime.now()
    for record in records:
        if record.return_date and record.return_date &lt; today and record.state == 'issued':
            record.write({
                'state': 'late',
                'remarks': 'Book is overdue – marked late automatically.',
            })
        </field>
    </record>

    <!-- Send Due Date Reminder (bulk) -->
    <record id="action_send_due_reminder_bulk" model="ir.actions.server">
        <field name="name">Send Due Date Reminder</field>
        <field name="model_id" ref="model_library_borrow"/>
        <field name="binding_model_id" ref="model_library_borrow"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">
if records:
    records.action_send_due_reminder()
        </field>
    </record>

</odoo>

