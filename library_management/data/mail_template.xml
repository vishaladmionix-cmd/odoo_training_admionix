<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <record id="email_template_member_registration" model="mail.template">
            <field name="name">Library Member Registration</field>
            <field name="model_id" ref="model_library_member"/>
            <field name="subject">Welcome to the Library, ${object.name}!</field>
            <field name="email_to">${object.email}</field>
            <field name="body_html" type="html">
                <p>Dear <t t-out="object.name"/>,</p>
                <p>Your library membership has been successfully registered.</p>
                <p>Thank you for joining us!</p>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>

        <record id="email_template_book_borrowed" model="mail.template">
            <field name="name">Book Borrowed</field>
            <field name="model_id" ref="model_library_borrow"/>
            <field name="subject">Book Issued - {{object.book_id.name}}</field>
            <field name="subject">Welcome to the Library, {{object.name}}!</field>

<!--            <field name="subject">Book Issued - ${object.book_id.name}</field>-->
<!--            <field name="email_to">${object.member_id.email or ''}</field>-->

           <field name="body_html" type="html">
                <div style="margin:0; padding:0;">
                    <p style="font-size:13px;">
                        Hello <t t-out="object.member_id.name or ''"/>,
                        <br/><br/>

                        You have borrowed
                        <b><t t-out="object.book_id.name or ''"/></b>.
                        <br/><br/>

                        Return Date:
                        <t t-out="object.return_date or ''"/>
                        <br/><br/>

                        Please return the book on time.
                        <br/><br/>

                        Thank you,<br/>
                        Library Team
                    </p>
                </div>
            </field>
        </record>

    </data>
</odoo>