<odoo>
    <template id="library_borrow_report_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="borrow">
                <div class="page">
                    <h2>Borrow Receipt</h2>
                    <p>
                        <strong>Borrow Ref:</strong>
                        <t t-esc="borrow.name"/>
                    </p>
                    <p>
                        <strong>Member:</strong>
                        <t t-esc="borrow.member_id.name"/>
                    </p>
                    <p>
                        <strong>Book:</strong>
                        <t t-esc="borrow.book_id.name"/>
                    </p>
                    <p>
                        <strong>Borrow Date:</strong>
                        <t t-esc="borrow.borrow_date"/>
                    </p>
                    <p>
                        <strong>Return Date:</strong>
                        <t t-esc="borrow.return_date"/>
                    </p>
                    <p>
                        <strong>State:</strong>
                        <t t-esc="borrow.state"/>
                    </p>
                    <p>
                        <strong>Fine Amount:</strong>
                        <t t-esc="borrow.fine_amount"/>
                    </p>
                </div>
            </t>
        </t>
    </template>
</odoo>




