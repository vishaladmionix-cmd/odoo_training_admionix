<odoo>

    <!-- Custom Groups -->
    <record id="module_library_category" model="ir.module.category">
        <field name="name">Library</field>
        <field name="sequence">17</field>
    </record>

    <record model="res.groups.privilege" id="privilege_category_library">
        <field name="name">Library Role</field>
        <field name="sequence">1</field>
        <field name="category_id" ref="module_library_category"/>
        <field name="placeholder">Select Role</field>
    </record>

    <record id="group_library_group_user" model="res.groups">
        <field name="name">Group library User</field>
        <field name="privilege_id" ref="privilege_category_library"/>
        <field name="comment">Basic access to Group library</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_library_group_manager" model="res.groups">
        <field name="name">Group library Manager</field>
        <field name="privilege_id" ref="privilege_category_library"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

</odoo>