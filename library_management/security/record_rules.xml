<odoo>
    <data noupdate="1">

        <!-- ── LIBRARIAN: full access to all models ── -->
        <record id="library_book_rule_librarian" model="ir.rule">
            <field name="name">Books: Librarian Full Access</field>
            <field name="model_id" ref="model_library_book"/>
            <field name="groups" eval="[(4, ref('library_management.group_library_librarian'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="library_member_rule_librarian" model="ir.rule">
            <field name="name">Member: Librarian Full Access</field>
            <field name="model_id" ref="model_library_member"/>
            <field name="groups" eval="[(4, ref('library_management.group_library_librarian'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="library_borrow_rule_librarian" model="ir.rule">
            <field name="name">Borrow: Librarian Full Access</field>
            <field name="model_id" ref="model_library_borrow"/>
            <field name="groups" eval="[(4, ref('library_management.group_library_librarian'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <!-- ── MEMBER: restricted access ── -->

        <!-- Member can only see their own member record -->
        <!--        <record id="library_member_rule_own" model="ir.rule">-->
        <!--            <field name="name">Member: Own Records Only</field>-->
        <!--            <field name="model_id" ref="model_library_member"/>-->
        <!--            <field name="groups" eval="[(4, ref('library_management.group_library_member'))]"/>-->
        <!--            <field name="domain_force">['|', ('user_id', '=', user.id), ('user_id', '=', False)]</field>-->
        <!--        </record>-->

        <!-- Member can only see their own borrow records -->
        <!--        <record id="library_borrow_rule_member" model="ir.rule">-->
        <!--            <field name="name">Borrow: Own Records Only</field>-->
        <!--            <field name="model_id" ref="model_library_borrow"/>-->
        <!--            <field name="groups" eval="[(4, ref('library_management.group_library_member'))]"/>-->
        <!--            <field name="domain_force">[('member_id.user_id', '=', user.id)]</field>-->
        <!--        </record>-->

        <!-- Member can read all books -->
        <record id="library_book_rule_member" model="ir.rule">
            <field name="name">Books: Available Only</field>
            <field name="model_id" ref="model_library_book"/>
            <field name="groups" eval="[(4, ref('library_management.group_library_member'))]"/>
            <field name="domain_force">[('state', '=', 'available')]</field>
        </record>

    </data>
</odoo>