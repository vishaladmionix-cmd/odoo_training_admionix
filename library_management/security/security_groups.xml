<odoo>
    <data noupdate="1" >

        <!-- ============================================================
             Layer 1: Module Category (Top-level App Group in Settings)
        ============================================================ -->
        <record id="module_library_management_category" model="ir.module.category">
            <field name="name">Library Management</field>
            <field name="sequence">18</field>
        </record>

        <!-- ============================================================
             Layer 2: Privilege Selector (Role Dropdown on User Form)
        ============================================================ -->
        <record id="privilege_category_library" model="res.groups.privilege">
            <field name="name">Library</field>
            <field name="sequence">1</field>
            <field name="category_id" ref="module_library_management_category"/>
            <field name="placeholder">Select Role</field>
        </record>

        <!-- ============================================================
             Layer 3: Security Groups (Actual Roles)
        ============================================================ -->

        <record id="group_library_librarian" model="res.groups">
            <field name="name">Librarian</field>
            <field name="sequence">10</field>
            <field name="privilege_id" ref="privilege_category_library"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Librarian has full access to Books, Members and Borrowing records.</field>
        </record>

        <record id="group_library_member" model="res.groups">
            <field name="name">Member</field>
            <field name="sequence">20</field>
            <field name="privilege_id" ref="privilege_category_library"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Member can only view Books and their own Borrow records.</field>
        </record>

    </data>
</odoo>