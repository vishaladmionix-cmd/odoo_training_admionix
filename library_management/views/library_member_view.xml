<odoo>
    <!--  member model form view  -->
    <record id="view_library_member_form" model="ir.ui.view">
        <field name="name">library.member.form</field>
        <field name="model">library.member</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <!-- smart borrow btn -->
                    <div name="button_box" class="oe_button_box">
                        <button name="action_view_borrows"
                                string="Borrow"
                                type="object"
                                icon="fa-book">
                            <div class="o_stat_info">Borrow Count
                                <span class="o_stat_value">
                                    <field name="borrow_count"/>
                                </span>
                            </div>
                        </button>
                    </div>
                    <group>
                        <field name="name"/>
                        <field name="email"/>
                        <field name="phone"/>

                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!--  member model list view  -->
    <record id="view_library_member_list" model="ir.ui.view">
        <field name="name">library.member.list</field>
        <field name="model">library.member</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="borrow_count"/>
            </list>
        </field>
    </record>

    <!-- member model search view   -->
    <record id="view_library_member_search" model="ir.ui.view">
        <field name="name">library.member.search</field>
        <field name="model">library.member</field>
        <field name="arch" type="xml">
            <search>
                <group>
                    <filter name="name" string="Member" context="{'group_by':'name'}"/>
                </group>
            </search>
        </field>
    </record>
    <!--  member model action  -->
    <record id="action_library_member" model="ir.actions.act_window">
        <field name="name">Member</field>
        <field name="res_model">library.member</field>
        <field name="search_view_id" ref="view_library_member_search"/>
        <field name="view_mode">list,form,search</field>
    </record>

    <!--  menu for member model  -->
    <menuitem id="menu_library_member"
              name="Members"
              parent="menu_library_book_root"
              action="action_library_member"
              sequence="2"/>
</odoo>