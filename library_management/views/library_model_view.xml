<odoo>
    <!--  book model form view  -->
    <record id="view_library_book_form" model="ir.ui.view">
        <field name="name">library.book.form</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name" readonly="available_qty == 0"/>
                        <field name="isbn" readonly="available_qty == 0"/>
                        <field name="author" readonly="available_qty == 0"/>
                        <field name="price" readonly="available_qty == 0"/>
                        <field name="available_qty"/>
                        <field name="state" readonly="available_qty == 0"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- search  view model   -->
    <record id="view_library_model_search" model="ir.ui.view">
        <field name="name">library.book.search</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <search>
                <group>
                    <filter name="name" string="Book" context="{'group_by':'name'}"/>
                </group>
            </search>
        </field>
    </record>

    <!--  book model list view  -->
    <record id="view_library_book_list" model="ir.ui.view">
        <field name="name">library.book.list</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="author"/>
                <field name="isbn"/>
                <field name="price"/>
                <field name="available_qty"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!--  book model form action  -->
    <record id="action_library_book" model="ir.actions.act_window">
        <field name="name">Books</field>
        <field name="res_model">library.book</field>
        <field name="search_view_id" ref="view_library_model_search"/>
        <field name="view_mode">list,form,search</field>
    </record>

    <!--  menu for book model root  -->
    <menuitem id="menu_library_book_root" name="Library Management"/>

    <!--  menu for book model -->
    <menuitem id="menu_library_book"
              name="Books"
              parent="menu_library_book_root"
              action="action_library_book"
              sequence="1"/>

</odoo>