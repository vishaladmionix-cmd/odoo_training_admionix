<odoo>

    <record id = "view_orm_practice_student_list" model="ir.ui.view">
        <field name="name">orm.practice.student.list</field>
        <field name="model">orm.practice.student</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="age"/>
                <field name="email"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_orm_practice_student_form" model="ir.ui.view">
        <field name="name">orm.practice.student.form</field>
        <field name="model">orm.practice.student</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="age"/>
                        <field name="email"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_orm_practice_student" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">orm.practice.student</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_orm_practice_root" name="ORM Practice"/>
    <menuitem id="menu_orm_practice_student"
              name="Students"
              parent="menu_orm_practice_root"
              action="action_orm_practice_student"/>





</odoo>