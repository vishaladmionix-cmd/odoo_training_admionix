<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_wizard_view_form" model="ir.ui.view">
        <field name="name">sale.order.wizard.view.form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Button in header -->
            <xpath expr="//header" position="inside">
                <button name="action_open_wizard"
                        type="object"
                        class="btn-primary"
                        string="Create Sale"/>
            </xpath>

            <!-- Tab with custom fields -->
            <xpath expr="//notebook" position="inside">
                <page string="Extra Information">
                    <group>
                        <group string="General">
                            <field name="custom_reference"/>
                            <field name="custom_note"/>
                        </group>
                    </group>
                </page>
            </xpath>

        </field>
    </record>
</odoo>