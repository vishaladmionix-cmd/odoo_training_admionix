<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_wizard" model="ir.ui.view">
        <field name="name">sale.wizard.form</field>
        <field name="model">sale.wizard</field>
        <field name="arch" type="xml">
            <form string="Manage Sale Order">
                <sheet>
                    <group>
                        <field name="order_id" invisible="1"/>
                        <field name="order_line_id" widget="many2many_tags" create="0" no_open="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_apply"
                            type="object"
                            string="Apply"
                            class="btn-primary"/>
                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>