<odoo>

    <!-- ========================= -->
    <!-- Tree View -->
    <!-- ========================= -->
    <record id="view_school_management_list" model="ir.ui.view">
        <field name="name">school.management.list</field>
        <field name="model">school.management</field>
        <field name="arch" type="xml">
            <list string="Students">
                <field name="name"/>
                <field name="age"/>
                <field name="email"/>
                <field name="teacher_id"/>
                <field name="is_minor"/>
            </list>
        </field>
    </record>

    <!-- ========================= -->
    <!-- Form View -->
    <!-- ========================= -->
    <record id="view_school_management_form" model="ir.ui.view">
        <field name="name">school.management.form</field>
        <field name="model">school.management</field>
        <field name="arch" type="xml">
            <form string="Student">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="age"/>
                        <field name="email"/>
                        <field name="teacher_id"/>
                        <field name="is_minor" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ========================= -->
    <!-- Action -->
    <!-- ========================= -->
    <record id="action_school_management_students" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">school.management</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ========================= -->
    <!-- Menus -->
    <!-- ========================= -->
    <menuitem id="menu_school_root" name="School"/>
    <menuitem id="menu_school_students"
              name="Students"
              parent="menu_school_root"
              action="action_school_management_students"/>

</odoo>
