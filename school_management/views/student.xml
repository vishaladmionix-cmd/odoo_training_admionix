<odoo>

    <!-- ========================= -->
    <!-- List View -->
    <!-- ========================= -->

    <record id="view_school_management_list" model="ir.ui.view">
        <field name="name">school.management.list</field>
        <field name="model">school.management</field>
        <field name="arch" type="xml">
            <list string="Students">
                <field name="name"/>
                <field name="age"/>
                <field name="email"/>
                <field name="teacher_id"/>
                <field name="is_minor"/>
            </list>
        </field>
    </record>

    <!-- ========================= -->
    <!-- Form View -->
    <!-- ========================= -->
<record id="view_school_management_form" model="ir.ui.view">
    <field name="name">school.management.form</field>
    <field name="model">school.management</field>
    <field name="arch" type="xml">
        <form string="Student">
            <sheet>

                <notebook>

                    <!-- Tab 1: Student Info -->
                    <page string="Student Info">
                        <group>
                            <field name="name"/>
                            <field name="age"/>
                            <field name="email"/>
                            <field name="is_minor" readonly="1"/>


                             <field name="entry_progress"/>

                            <!-- ✅ Gauge -->
                            <field name="entry_progress"
                                   widget="gauge"
                                   options="{'max_field': 'maximum_rate'}"/>
                        </group>
                    </page>

                    <!-- Tab 2: Teacher -->
                    <page string="Teacher">
                        <group>
                            <field name="teacher_id"/>
                        </group>
                    </page>

                    <!-- Tab 3: Subjects -->
                    <page string="Subjects">
                        <group>
                            <field name="subject_ids" widget="many2many_tags"/>
                        </group>
                    </page>

                </notebook>

                <footer>
                    <button name="action_create_test_student"
                            type="object"
                            string="Create Test Student"
                            class="btn-primary"/>
                </footer>

            </sheet>
        </form>
    </field>
</record>


    <!-- ========================= -->
    <!-- Action -->
    <!-- ========================= -->

    <record id="action_school_management_students" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">school.management</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ========================= -->
    <!-- Menus -->
    <!-- ========================= -->

    <menuitem id="menu_school_root" name="School"/>
    <menuitem id="menu_school_students"
              name="Students"
              parent="menu_school_root"
              action="action_school_management_students"/>

</odoo>
